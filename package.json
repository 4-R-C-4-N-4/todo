{
  "name": "todo",
  "version": "1.0.0",
  "description": "Making working on work work",
  "main": "dist/cli.js",
  "bin": {
    "todo": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/local/todo.git"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/cli.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/usr/bin/env node')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)}\"",
    "test": "vitest run",
    "dev": "ts-node src/cli.ts",
    "check": "tsc --noEmit"
  },
  "type": "commonjs",
  "keywords": ["todo", "git", "ticket", "cli"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "commander": "^14.0.0"
  }
}
